{
  "name": "work-wise-tracker",
  "displayName": "Work wise tracker",
  "version": "0.0.1",
  "description": "A specialized browser extension designed to monitor employee activity on the Encord platform. It tracks task completion times, monitors idle periods, and analyzes UI interactions to provide actionable efficiency insights.",
  "author": "Himanshu Machhi",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "storage",
      "alarms",
      "activeTab",
      "tabs",
      "idle"
    ]
  }
}
